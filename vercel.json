{
  "routes": [
    {
      "src": "/ingest/static/(.*)",
      "dest": "https://eu-assets.i.posthog.com/static/$1",
      "headers": {
        "Access-Control-Allow-Origin": "*"
      }
    },
    {
      "src": "/ingest/(.*)",
      "dest": "https://eu.i.posthog.com/$1",
      "headers": {
        "Access-Control-Allow-Origin": "*"
      }
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
